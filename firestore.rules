rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: closed to everyone unless explicitly allowed below
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow anyone to view a specific portal if they have the ID, but only agents can list/edit them
    match /client_portals/{portalId} {
      allow get: if true;
      allow list, write: if request.auth != null;
    }
  }
}
