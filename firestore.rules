rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: closed to everyone unless explicitly allowed below
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow agents to read/write Client Portals
    match /client_portals/{portalId} {
      allow read, write: if request.auth != null;
    }
  }
}
